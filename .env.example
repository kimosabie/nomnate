# Supabase — get these from your Supabase project dashboard
# Web (Next.js) — prefix with NEXT_PUBLIC_
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Mobile (Expo) — prefix with EXPO_PUBLIC_
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI — Anthropic (Claude) — server-side only
ANTHROPIC_API_KEY=sk-ant-...

# Recipes — Spoonacular — server-side only
SPOONACULAR_API_KEY=your-spoonacular-key

# Admin — system health / metrics access
# ADMIN_EMAIL: primary "headless" admin (redirected straight to /admin/dashboard)
ADMIN_EMAIL=admin@example.com
# ADMIN_EMAILS: optional comma-separated extra admins who use the app normally
# but can also view the admin pages (link appears on their profile)
ADMIN_EMAILS=
